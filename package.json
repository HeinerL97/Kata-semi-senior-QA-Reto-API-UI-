  "main": "index.js",
  "scripts": {
    "test": "npm run test:bdd",
    "test:bdd": "npx cucumber-js --require features/support/**/*.js --require features/steps/**/*.js --format allure-cucumberjs/reporter",
    "test:bdd:api": "npx cucumber-js --require features/support/**/*.js --require features/steps/**/*.js --format allure-cucumberjs/reporter features/api-users.feature",
    "test:bdd:ui": "npx cucumber-js --require features/support/**/*.js --require features/steps/**/*.js --format allure-cucumberjs/reporter features/ui-contact.feature",
    "allure:generate": "npx allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "npx allure open ./allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "allure-commandline": "^2.23.0",
    "allure-cucumberjs": "^3.10.0",
    "allure-js-commons": "^3.10.0",
    "allure-playwright": "^3.10.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
